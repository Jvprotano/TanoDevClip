---
import { siteConfig } from '../config/site';
---

<section class="cta-section" aria-labelledby="download-title">
  <div class="container cta-inner">
    <p class="status mono"><span aria-hidden="true">&gt;</span> ready_to_install=true</p>
    <h2 id="download-title" class="title">Make your clipboard part of your development workflow.</h2>
    <p class="description">Install TanoDev Clip for Windows or inspect the latest release before downloading.</p>

    <div class="actions">
      <a href={siteConfig.downloadUrl} class="button button-primary button-large">
        Download for Windows
      </a>
      <a
        href={siteConfig.latestReleaseUrl}
        class="button button-large"
        target="_blank"
        rel="noopener noreferrer"
      >
        View latest release
        <span class="sr-only"> (opens in a new tab)</span>
      </a>
    </div>

    <a
      class="source-link mono"
      href={siteConfig.repositoryUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      View source on GitHub
      <span class="sr-only"> (opens in a new tab)</span>
    </a>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .status {
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
    font-size: 0.82rem;
  }

  .title {
    max-width: 720px;
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .description {
    max-width: 620px;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .source-link {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .source-link:hover {
    color: var(--color-action-hover);
  }

  @media (min-width: 640px) {
    .actions {
      flex-direction: row;
    }
  }
</style>
