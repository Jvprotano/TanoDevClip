---
---

<section class="privacy-section">
  <div class="container">
    <div class="card">
      <div class="content">
        <h2 class="title">Local-first by design</h2>
        <p class="description">
          Your clipboard history is stored exclusively in a local SQLite database 
          on your machine. TanoDev Clip does not send your data to a remote server, 
          does not require an account, and does not include cloud synchronization.
        </p>
      </div>
      <div class="icon-container">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .privacy-section {
    padding: var(--space-2xl) 0;
  }
  
  .card {
    background-color: var(--color-bg-panel);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-xl);
  }
  
  @media (min-width: 640px) {
    .card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  
  .content {
    max-width: 600px;
  }
  
  .title {
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }
  
  .description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  
  .icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background-color: var(--color-accent-muted);
    border: 1px solid var(--color-border-accent);
    border-radius: 50%;
    color: var(--color-accent);
    box-shadow: var(--shadow-glow);
  }
</style>
