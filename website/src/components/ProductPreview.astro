---
import { siteConfig, withBase } from '../config/site';

const { appPreviewImage, appPreviewVideo } = siteConfig.media;
---

<section class="preview" aria-label="TanoDev Clip product preview">
  <div class="container">
    <div class="window-frame">
      <div class="titlebar">
        <div class="titlebar-title mono">
          <span class="prompt" aria-hidden="true">&gt;</span> TanoDev Clip
        </div>
        <div class="titlebar-controls" aria-hidden="true">
          <span class="control minimize"></span>
          <span class="control maximize"></span>
          <span class="control close"></span>
        </div>
      </div>

      <div class="window-content">
        {appPreviewVideo ? (
          <video
            class="preview-media"
            controls
            muted
            playsinline
            preload="metadata"
            poster={appPreviewImage ? withBase(appPreviewImage) : undefined}
          >
            <source src={withBase(appPreviewVideo)} />
            Your browser does not support embedded video.
          </video>
        ) : appPreviewImage ? (
          <img
            src={withBase(appPreviewImage)}
            alt="TanoDev Clip showing clipboard history and developer tools"
            class="preview-media"
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div
            class="media-placeholder"
            role="img"
            aria-label="Placeholder for a future TanoDev Clip screenshot or product video"
          >
            <div class="placeholder-content mono">
              <span><span class="prompt" aria-hidden="true">&gt;</span> product preview pending</span>
              <small>Add a screenshot or video under <code>website/public/media</code>, then set its path in <code>src/config/site.ts</code>.</small>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .preview {
    margin-bottom: var(--space-4xl);
  }

  .window-frame {
    max-width: 900px;
    margin: 0 auto;
    background-color: var(--color-bg-root);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    overflow: hidden;
  }

  .titlebar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 34px;
    background-color: rgba(14, 23, 27, 0.96);
    border-bottom: 1px solid var(--color-border-subtle);
    padding: 0 var(--space-md);
  }

  .titlebar-title {
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .prompt {
    color: var(--color-accent);
  }

  .titlebar-controls {
    display: flex;
    gap: 8px;
  }

  .control {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid var(--color-border-strong);
  }

  .close { border-color: var(--color-danger); }
  .minimize { border-color: var(--color-warning); }
  .maximize { border-color: var(--color-action); }

  .window-content {
    min-height: 400px;
    display: flex;
    background-color: var(--color-bg-root);
  }

  .preview-media {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: var(--color-bg-root);
  }

  .media-placeholder {
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
    text-align: center;
    background-image:
      linear-gradient(45deg, var(--color-bg-panel) 25%, transparent 25%, transparent 75%, var(--color-bg-panel) 75%),
      linear-gradient(45deg, var(--color-bg-panel) 25%, transparent 25%, transparent 75%, var(--color-bg-panel) 75%);
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
  }

  .placeholder-content {
    max-width: 620px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--color-text);
  }

  .placeholder-content small {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .placeholder-content code {
    color: var(--color-action);
  }

  @media (max-width: 639px) {
    .window-content,
    .media-placeholder {
      min-height: 260px;
    }
  }
</style>
