---
import { siteConfig } from '../config/site';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="eyebrow mono">
        <span class="prompt" aria-hidden="true">&gt;</span> tanodev-clip --open
        <span class="cursor" aria-hidden="true"></span>
      </div>

      <h1 id="hero-title" class="title">Your clipboard,<br />built for development.</h1>

      <p class="description">
        Search your clipboard history, paste back into any application,
        and access useful developer tools without leaving your workflow.
      </p>

      <div class="actions">
        <a href={siteConfig.downloadUrl} class="button button-primary button-large">
          Download for Windows
        </a>
        <a
          href={siteConfig.repositoryUrl}
          class="button button-large"
          target="_blank"
          rel="noopener noreferrer"
        >
          View source on GitHub
          <span class="sr-only"> (opens in a new tab)</span>
        </a>
      </div>

      <div class="metadata mono" aria-label="Product information">
        <span>Windows 10/11</span>
        <span class="separator" aria-hidden="true">/</span>
        <span>64-bit</span>
        <span class="separator" aria-hidden="true">/</span>
        <span>Local-first</span>
        <span class="separator" aria-hidden="true">/</span>
        <span>Open source</span>
        <span class="separator" aria-hidden="true">/</span>
        <span>No account required</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    padding: 4px 12px;
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
  }

  .prompt {
    color: var(--color-accent);
  }

  .cursor {
    display: inline-block;
    width: 6px;
    height: 1.1em;
    background-color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
    background: linear-gradient(180deg, #ffffff 0%, var(--color-text) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .description {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    margin: 0 auto var(--space-2xl);
    max-width: 620px;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-xl);
  }

  .metadata {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .separator {
    color: var(--color-border-strong);
  }

  @media (min-width: 640px) {
    .actions {
      flex-direction: row;
    }
  }

  @media (max-width: 479px) {
    .hero {
      padding-top: var(--space-3xl);
    }

    .metadata .separator {
      display: none;
    }

    .metadata span:not(.separator) {
      padding: 2px 7px;
      border: 1px solid var(--color-border-subtle);
      border-radius: var(--radius-sm);
    }
  }
</style>
