---
const downloadUrl = "https://github.com/Jvprotano/TanoDevClip/releases/latest/download/ProtanoSoftware.TanoDevClip-Setup.exe";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="eyebrow mono">
        <span class="prompt">&gt;</span> tanodev-clip --open
        <span class="cursor"></span>
      </div>
      
      <h1 class="title">Your clipboard,<br/>built for development.</h1>
      
      <p class="description">
        Search your clipboard history, paste back into any application,
        and access useful developer tools without leaving your workflow.
      </p>
      
      <div class="actions">
        <a href={downloadUrl} class="button primary large">
          Download for Windows
        </a>
        <a href="https://github.com/Jvprotano/TanoDevClip" class="button ghost large">
          View source on GitHub
        </a>
      </div>
      
      <div class="metadata mono">
        <span>Windows 10/11</span>
        <span class="separator">/</span>
        <span>64-bit</span>
        <span class="separator">/</span>
        <span>Local-first</span>
        <span class="separator">/</span>
        <span>Open source</span>
        <span class="separator">/</span>
        <span>No account required</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    position: relative;
    overflow: hidden;
  }
  
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .hero-content {
    max-width: 800px;
  }
  
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    padding: 4px 12px;
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
  }
  
  .prompt {
    color: var(--color-accent);
  }
  
  .cursor {
    display: inline-block;
    width: 6px;
    height: 1.1em;
    background-color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
    background: linear-gradient(180deg, #ffffff 0%, var(--color-text) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .description {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-xl);
  }
  
  @media (min-width: 640px) {
    .actions {
      flex-direction: row;
    }
  }
  
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
    border: 1px solid var(--color-border-strong);
  }
  
  .button.large {
    font-size: 1.05rem;
  }
  
  .button.primary {
    background-color: var(--color-accent-muted);
    border-color: var(--color-border-accent);
    color: var(--color-accent);
  }
  
  .button.primary:hover {
    background-color: rgba(85, 249, 145, 0.2);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-1px);
  }
  
  .button.ghost {
    background-color: transparent;
    color: var(--color-text);
  }
  
  .button.ghost:hover {
    background-color: var(--color-bg-panel);
    border-color: var(--color-text-muted);
  }
  
  .metadata {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  
  .separator {
    color: var(--color-border-strong);
  }
</style>
