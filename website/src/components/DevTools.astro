---
const baseUrl = import.meta.env.BASE_URL;

const generators = [
  "GUID generation",
  "CPF generation",
  "CNPJ generation",
  "Lorem Ipsum generation",
  "Random string generation"
];

const transformers = [
  "JWT decode",
  "JSON format",
  "Base64 encode / decode",
  "URL encode / decode",
  "Regex tester"
];
---

<section id="devtools" class="devtools-section">
  <div class="container">
    <div class="header">
      <h2 class="title mono"><span class="prompt">&gt;</span> ./devtools</h2>
      <p class="description">
        Access small developer utilities directly within your clipboard workflow. 
        Generated output is automatically copied to your history.
      </p>
    </div>
    
    <div class="layout">
      <div class="tools-grid">
        <div class="tool-group">
          <h3 class="group-title mono">Generate</h3>
          <ul class="tool-list">
            {generators.map(tool => (
              <li>
                <span class="bullet mono">-</span>
                {tool}
              </li>
            ))}
          </ul>
        </div>
        
        <div class="tool-group">
          <h3 class="group-title mono">Transform</h3>
          <ul class="tool-list">
            {transformers.map(tool => (
              <li>
                <span class="bullet mono">-</span>
                {tool}
              </li>
            ))}
          </ul>
        </div>
      </div>
      
      <div class="preview-container">
        <!-- Using a placeholder pattern that feels technical -->
        <div class="placeholder">
          <img 
            src={`${baseUrl}/assets/devtools-demo.png`} 
            alt="TanoDev Clip Developer Tools showing the JSON Formatter"
            class="screenshot"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="fallback-placeholder">
            <div class="mono">
              <span class="prompt">&gt;</span> awaiting visual asset...<br/>
              <span class="muted">// Place 'devtools-demo.png' in src/assets/</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .devtools-section {
    padding: var(--space-4xl) 0;
  }
  
  .header {
    margin-bottom: var(--space-3xl);
    max-width: 600px;
  }
  
  .title {
    font-size: 2rem;
    color: var(--color-action);
    margin-bottom: var(--space-md);
  }
  
  .prompt {
    color: var(--color-action-muted);
  }
  
  .description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  
  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
  }
  
  @media (min-width: 768px) {
    .layout {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  
  @media (min-width: 480px) {
    .tools-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .group-title {
    font-size: 1.05rem;
    color: var(--color-warning);
    margin-bottom: var(--space-md);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  
  .tool-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .tool-list li {
    display: flex;
    gap: var(--space-sm);
    color: var(--color-text);
  }
  
  .bullet {
    color: var(--color-border-strong);
  }
  
  .preview-container {
    background-color: var(--color-bg-panel);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-sm);
  }
  
  .placeholder {
    width: 100%;
    display: flex;
    border: 1px solid var(--color-border-strong);
    background-color: var(--color-bg-root);
  }
  
  .screenshot {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .fallback-placeholder {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 4/3;
    text-align: center;
    font-size: 0.9rem;
    background-image: linear-gradient(45deg, var(--color-bg-panel) 25%, transparent 25%, transparent 75%, var(--color-bg-panel) 75%, var(--color-bg-panel)), linear-gradient(45deg, var(--color-bg-panel) 25%, transparent 25%, transparent 75%, var(--color-bg-panel) 75%, var(--color-bg-panel));
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
  }
  
  .muted {
    color: var(--color-text-muted);
  }
</style>
